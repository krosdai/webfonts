{
  "packageManager": "pnpm@11.8.0+sha512.c1f5e7c4cb241c8f174b743851d82f42b802324afc8b0f116b96adb15aa06664948dde36960a3ba1079ba5b4b29dd0140135b94b5b5f5263592249d68e555f26",
  "private": true,
  "engines": {
    "node": ">=22.22.1"
  },
  "scripts": {
    "format": "prettier --write --ignore-unknown --log-level=warn . && autocorrect --fix .",
    "lint": "eslint . --no-error-on-unmatched-pattern && pnpm run --filter '*' --if-present lint && prettier --check --ignore-unknown .",
    "lint:staged": "lint-staged",
    "lint:fix": "eslint . --no-error-on-unmatched-pattern --fix && pnpm run --filter '*' --if-present lint:fix && pnpm run format",
    "prepare": "husky",
    "build:fonts": "tsx scripts/build-fonts.ts",
    "verify:fonts": "tsx scripts/verify-fonts.ts",
    "catalog": "tsx scripts/build-fonts.ts --catalog-only",
    "pack:fonts": "pnpm build:fonts -- --clean && pnpm verify:fonts && tsx scripts/pack-fonts.ts",
    "release": "pnpm build:fonts -- --clean && pnpm verify:fonts && pnpm -r publish --access public --no-git-checks"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.9.2",
    "autocorrect-node": "^2.14.0",
    "cn-font-split": "7.4.2",
    "eslint": "^10.4.1",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "prettier": "^3.8.3",
    "tar": "^7.5.16",
    "tsx": "^4.22.4",
    "typescript-eslint": "^8.60.1",
    "zod": "^4.4.3"
  }
}
